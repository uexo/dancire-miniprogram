# 环境变量模板
# 复制本文件为 .env 并填入实际值

# ============================================
# 应用基础配置
# ============================================

# 运行环境: development | production | test
NODE_ENV=development

# 服务端口号
PORT=3000

# JWT 密钥（生产环境必须修改！）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# 数据库配置（双模式支持）
# ============================================

# 数据库类型: sqlite | mysql
DB_TYPE=sqlite

# SQLite 配置（开发环境）
SQLITE_PATH=./wordheat.db

# MySQL 配置（生产环境）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=wordheat
# DB_PASSWORD=your-mysql-password
# DB_NAME=wordheat

# ============================================
# 微信小程序配置
# ============================================

# 小程序 AppID
WX_APPID=wx1234567890abcdef

# 小程序 AppSecret
WX_SECRET=your-wx-app-secret

# ============================================
# 微信支付配置（用于VIP会员）
# ============================================

# 微信支付商户号
WX_MCH_ID=1234567890

# 微信支付 API 密钥
WX_API_KEY=your-wx-pay-api-key

# 支付回调 URL（必须外网可访问）
WX_NOTIFY_URL=https://api.wordheat.com/api/v1/payment/notify

# 商户证书路径（退款需要）
WX_CERT_PATH=/path/to/apiclient_cert.pem
WX_KEY_PATH=/path/to/apiclient_key.pem

# ============================================
# TTS 语音配置（可选）
# ============================================

# TTS 服务 App ID（如百度语音、腾讯云等）
TTS_APP_ID=your-tts-app-id

# TTS API Key
TTS_API_KEY=your-tts-api-key

# TTS 密钥
TTS_SECRET_KEY=your-tts-secret-key

# ============================================
# Redis 配置（可选，用于缓存和会话）
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# 日志配置
# ============================================

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=./logs/app.log

# ============================================
# 其他配置
# ============================================

# 每日学习单词上限
DAILY_WORD_LIMIT=50

# 打卡金币基础值
CHECKIN_BASE_COIN=10

# API 速率限制（每分钟请求数）
RATE_LIMIT=100

/**app.wxss**/
/* 单词热 - 全局样式 */
/* 基于 PRD 6.7 Design Tokens */

/* ========== 颜色系统 ========== */
/* 主色 */
page {
  --primary: #6D28D9;
  --primary-hover: #7C3AED;
  --primary-active: #5B21B6;
  --primary-disabled: #C4B5FD;
  
  /* 功能色 */
  --info: #3B82F6;
  --success: #10B981;
  --warning: #F59E0B;
  --error: #EF4444;
  
  /* 中性色 */
  --gray-900: #111827;
  --gray-800: #1F2937;
  --gray-700: #374151;
  --gray-600: #6B7280;
  --gray-500: #9CA3AF;
  --gray-400: #D1D5DB;
  --gray-300: #E5E7EB;
  --gray-200: #F3F4F6;
  --gray-100: #FAFAFA;
  --white: #FFFFFF;
  
  /* tabBar */
  --tabbar-color: #65728c;
  --tabbar-selected: #6D28D9;
  --tabbar-bg: #ffffff;
}

/* ========== 基础样式 ========== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 16px;
  line-height: 1.5;
  color: var(--gray-900);
  background-color: var(--gray-100);
}

/* 容器 */
.container {
  padding: 16px;
  box-sizing: border-box;
}

/* ========== 文本样式 ========== */
.text-h1 {
  font-size: 24px;
  line-height: 32px;
  font-weight: 600;
}

.text-h2 {
  font-size: 20px;
  line-height: 28px;
  font-weight: 600;
}

.text-h3 {
  font-size: 18px;
  line-height: 26px;
  font-weight: 600;
}

.text-body {
  font-size: 16px;
  line-height: 24px;
}

.text-caption {
  font-size: 14px;
  line-height: 20px;
}

.text-micro {
  font-size: 12px;
  line-height: 18px;
}

/* ========== 按钮样式 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 12px 24px;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 500;
  transition: all 0.1s ease-out;
}

.btn-primary {
  background-color: var(--primary);
  color: var(--white);
}

.btn-primary:active {
  background-color: var(--primary-active);
  transform: scale(0.98);
}

.btn-secondary {
  background-color: var(--white);
  border: 1px solid var(--primary);
  color: var(--primary);
}

.btn-secondary:active {
  background-color: var(--gray-200);
}

.btn-disabled {
  background-color: var(--primary-disabled);
  color: var(--gray-100);
}

/* ========== 卡片样式 ========== */
.card {
  background-color: var(--white);
  border-radius: 12px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.08);
  padding: 16px;
  margin-bottom: 16px;
}

.card-selected {
  border: 2px solid var(--primary);
}

/* ========== 进度条 ========== */
.progress-bar {
  height: 8px;
  background-color: var(--gray-300);
  border-radius: 8px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: var(--primary);
  border-radius: 8px;
  transition: width 0.3s ease-out;
}

/* ========== 徽章标签 ========== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
}

.badge-primary {
  background-color: var(--primary);
  color: var(--white);
}

.badge-success {
  background-color: var(--success);
  color: var(--white);
}

/* ========== 间距系统 ========== */
.m-4 { margin: 4px; }
.m-8 { margin: 8px; }
.m-12 { margin: 12px; }
.m-16 { margin: 16px; }
.m-24 { margin: 24px; }
.m-32 { margin: 32px; }

.p-4 { padding: 4px; }
.p-8 { padding: 8px; }
.p-12 { padding: 12px; }
.p-16 { padding: 16px; }
.p-24 { padding: 24px; }
.p-32 { padding: 32px; }

/* ========== Flex 工具类 ========== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

/* ========== 工具类 ========== */
.text-center { text-align: center; }
.text-primary { color: var(--primary); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-error { color: var(--error); }
.text-gray { color: var(--gray-600); }

.bg-white { background-color: var(--white); }
.bg-gray { background-color: var(--gray-100); }

.rounded { border-radius: 12px; }
.shadow { box-shadow: 0 4px 8px rgba(0, 0, 0, 0.08); }

/* ========== 安全区适配 ========== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

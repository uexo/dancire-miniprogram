/* pages/checkin/checkin.wxss */
.checkin-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  color: #fff;
  text-align: center;
}

.continuous-days {
  font-size: 120rpx;
  font-weight: bold;
  line-height: 1;
}

.days-label {
  font-size: 32rpx;
  margin-top: 20rpx;
  opacity: 0.9;
}

.total-days {
  font-size: 28rpx;
  margin-top: 20rpx;
  opacity: 0.8;
}

/* 今日打卡按钮 */
.checkin-btn-section {
  padding: 40rpx;
  text-align: center;
  background: #fff;
  margin-bottom: 20rpx;
}

.checkin-btn {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  box-shadow: 0 10rpx 40rpx rgba(76, 175, 80, 0.4);
}

.checkin-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.checkin-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.checkin-text {
  font-size: 36rpx;
  font-weight: bold;
}

.checked-text {
  font-size: 28rpx;
}

/* 日历 */
.calendar-section {
  background: #fff;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.calendar-header {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.weekdays {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.weekday {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.day-cell {
  width: calc(100% / 7);
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  position: relative;
}

.day-cell.empty {
  background: transparent;
}

.day-cell.today {
  color: #4CAF50;
  font-weight: bold;
}

.day-cell.checked::after {
  content: '';
  position: absolute;
  bottom: 10rpx;
  width: 12rpx;
  height: 12rpx;
  background: #4CAF50;
  border-radius: 50%;
}

.day-cell.today.checked::after {
  background: #fff;
}

/* 连续打卡奖励 */
.rewards-section {
  background: #fff;
  padding: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.rewards-list {
  display: flex;
  justify-content: space-between;
}

.reward-item {
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  flex: 1;
  margin: 0 10rpx;
}

.reward-item.active {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.reward-item.claimed {
  background: #FFF3E0;
  opacity: 0.6;
}

.reward-day {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.reward-coin {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF9800;
  margin-bottom: 10rpx;
}

.reward-btn {
  font-size: 24rpx;
  color: #4CAF50;
  background: #fff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid #4CAF50;
}

.reward-btn.disabled {
  color: #999;
  border-color: #ccc;
}

/* pages/vip/vip.wxss */
.vip-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部banner */
.vip-header {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 60rpx 40rpx;
  text-align: center;
  color: #fff;
}

.vip-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.vip-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.vip-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.vip-status {
  background: rgba(255,255,255,0.2);
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  margin-top: 30rpx;
  display: inline-block;
}

/* 产品列表 */
.products-section {
  padding: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.product-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  border: 4rpx solid transparent;
  position: relative;
}

.product-item.selected {
  border-color: #FFD700;
  background: #FFFDF5;
}

.product-tag {
  position: absolute;
  top: -4rpx;
  right: 40rpx;
  background: #f44336;
  color: #fff;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
}

.product-duration {
  font-size: 26rpx;
  color: #999;
}

.product-price-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.price-symbol {
  font-size: 28rpx;
  color: #f44336;
}

.price-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #f44336;
}

.price-original {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 20rpx;
}

.product-features {
  display: flex;
  flex-wrap: wrap;
}

.feature-tag {
  background: #E8F5E9;
  color: #4CAF50;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 10rpx;
}

/* 权益说明 */
.benefits-section {
  background: #fff;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.benefits-list {
  display: flex;
  flex-wrap: wrap;
}

.benefit-item {
  width: 25%;
  text-align: center;
  padding: 20rpx 0;
}

.benefit-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.benefit-text {
  font-size: 24rpx;
  color: #666;
}

/* 底部支付栏 */
.pay-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pay-info {
  flex: 1;
}

.pay-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #f44336;
}

.pay-price text {
  font-size: 28rpx;
}

.pay-original {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.pay-btn {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  padding: 30rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

/** 登录页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4CAF50 0%, #45a049 40%, #f5f5f5 40%);
  display: flex;
  flex-direction: column;
}

/* 顶部背景 */
.header-bg {
  padding: 80rpx 40rpx 120rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录卡片 */
.login-card {
  flex: 1;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -40rpx;
  padding: 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 登录方式切换 */
.login-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #fff;
  color: #4CAF50;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 登录内容 */
.login-content {
  padding: 20rpx 0;
}

/* 微信登录 */
.wx-login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.wx-icon {
  width: 120rpx;
  height: 120rpx;
  background: #e8f5e9;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.wx-icon text {
  font-size: 60rpx;
}

.wx-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.wx-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.wx-login-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  font-weight: bold;
}

.wx-login-btn.secondary {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 手机号登录 */
.phone-login-section {
  padding: 20rpx 0;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: bold;
}

.input-wrap {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  height: 96rpx;
}

.input-prefix {
  font-size: 30rpx;
  color: #666;
  margin-right: 20rpx;
  padding-right: 20rpx;
  border-right: 2rpx solid #ddd;
}

.input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  height: 100%;
}

.code-wrap {
  padding-right: 12rpx;
}

.code-input {
  margin-right: 20rpx;
}

.send-code-btn {
  background: #4CAF50;
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  border: none;
  line-height: 1.5;
  min-width: 160rpx;
}

.send-code-btn.disabled {
  background: #ccc;
}

.login-btn {
  width: 100%;
  background: #4CAF50;
  color: #fff;
  font-size: 34rpx;
  padding: 30rpx 0;
  border-radius: 48rpx;
  border: none;
  margin-top: 40rpx;
  font-weight: bold;
}

/* 错误提示 */
.error-tip {
  background: #ffebee;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 30rpx;
}

.error-tip text {
  font-size: 28rpx;
  color: #f44336;
}

/* 用户协议 */
.protocol-section {
  margin-top: 40rpx;
}

.protocol-check {
  display: flex;
  align-items: flex-start;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #4CAF50;
  border-color: #4CAF50;
}

.checkbox text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.protocol-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.protocol-link {
  color: #4CAF50;
}

/* 游客模式 */
.guest-section {
  text-align: center;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.guest-link {
  font-size: 28rpx;
  color: #999;
  text-decoration: underline;
}

/* 底部版权 */
.footer {
  text-align: center;
  padding: 40rpx;
}

.footer text {
  font-size: 24rpx;
  color: #bbb;
}

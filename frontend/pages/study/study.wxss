/* pages/study/study.wxss */
.study-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

/* 进度条 */
.progress-bar {
  background: rgba(255,255,255,0.2);
  height: 8rpx;
  border-radius: 4rpx;
  margin-bottom: 30rpx;
}

.progress-fill {
  background: #fff;
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  color: #fff;
  font-size: 24rpx;
  text-align: right;
  margin-top: 10rpx;
}

/* 单词卡片 */
.word-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.1);
}

.word-title {
  font-size: 72rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 20rpx;
}

.phonetic {
  text-align: center;
  color: #666;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.audio-btn {
  width: 80rpx;
  height: 80rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.audio-icon {
  color: #fff;
  font-size: 40rpx;
}

/* 答案区域 */
.answer-section {
  margin-top: 40rpx;
}

.meaning {
  font-size: 36rpx;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.example {
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 10rpx;
}

/* 选项按钮 */
.options-list {
  margin-top: 30rpx;
}

.option-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-item.selected {
  border-color: #4CAF50;
  background: #E8F5E9;
}

.option-item.correct {
  border-color: #4CAF50;
  background: #E8F5E9;
}

.option-item.wrong {
  border-color: #f44336;
  background: #FFEBEE;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  margin: 0 10rpx;
  padding: 30rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-primary {
  background: #4CAF50;
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #666;
}

/* 底部统计 */
.stats-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
}

.stat-value.wrong {
  color: #f44336;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

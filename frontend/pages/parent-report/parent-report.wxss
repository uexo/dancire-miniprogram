/** 家长报告页样式 */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

/* 头部 */
.report-header {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.report-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: 1;
  margin-left: 20rpx;
}

.share-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 26rpx;
}

.share-icon {
  margin-right: 8rpx;
}

/* Tab切换 */
.tab-bar {
  background: #fff;
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 30rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active {
  color: #4CAF50;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #4CAF50;
  border-radius: 2rpx;
}

.badge {
  background: #ff5252;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  margin-left: 8rpx;
}

/* Tab内容 */
.tab-content {
  padding: 30rpx;
}

/* 核心数据卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  display: block;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 打卡统计 */
.checkin-stats {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.checkin-item {
  text-align: center;
}

.checkin-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #ff9800;
  display: block;
}

.checkin-label {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.checkin-divider {
  width: 2rpx;
  height: 60rpx;
  background: #eee;
}

/* 章节通用样式 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 记忆曲线 */
.memory-curve {
  padding-bottom: 20rpx;
}

.curve-chart {
  margin: 20rpx 0;
}

.curve-canvas {
  width: 100%;
  height: 400rpx;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.legend-line {
  width: 40rpx;
  height: 4rpx;
  margin-right: 12rpx;
  border-radius: 2rpx;
}

.legend-line.theoretical {
  background: #ccc;
}

.legend-line.actual {
  background: #4CAF50;
}

.curve-info {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 学习建议 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #f8f9fa;
}

.suggestion-item.success {
  background: #e8f5e9;
  border-left: 4rpx solid #4CAF50;
}

.suggestion-item.warning {
  background: #fff3e0;
  border-left: 4rpx solid #ff9800;
}

.suggestion-item.info {
  background: #e3f2fd;
  border-left: 4rpx solid #2196f3;
}

.suggestion-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.5;
  display: block;
}

/* 日历 */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.month-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.nav-arrow {
  font-size: 40rpx;
  color: #666;
}

.month-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.week-header {
  display: flex;
  margin-bottom: 16rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  position: relative;
}

.calendar-cell.empty {
  background: transparent;
}

.calendar-cell.day {
  background: #f5f5f5;
}

.calendar-cell.day.today {
  background: #e3f2fd;
  border: 2rpx solid #2196f3;
}

.calendar-cell.day.excellent {
  background: #4CAF50;
}

.calendar-cell.day.good {
  background: #8bc34a;
}

.calendar-cell.day.normal {
  background: #ffc107;
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.calendar-cell.day.excellent .day-number,
.calendar-cell.day.good .day-number,
.calendar-cell.day.normal .day-number {
  color: #fff;
}

.study-indicator {
  width: 8rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.legend-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.legend-dot.excellent {
  background: #4CAF50;
}

.legend-dot.good {
  background: #8bc34a;
}

.legend-dot.normal {
  background: #ffc107;
}

.legend-row text {
  font-size: 24rpx;
  color: #666;
}

/* 错题本 */
.wrongwords-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.wrongwords-count {
  font-size: 28rpx;
  color: #666;
}

.review-btn {
  background: #4CAF50;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  border: none;
  line-height: 1;
}

.wrongwords-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.wrongword-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.word-info {
  flex: 1;
}

.word-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.word-phonetic {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.word-meaning {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.word-stats {
  text-align: right;
}

.wrong-count {
  font-size: 26rpx;
  color: #ff5252;
  display: block;
}

.last-wrong {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #4CAF50;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

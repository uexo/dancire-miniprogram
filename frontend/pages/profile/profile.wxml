<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info" wx:if="{{isLogin}}">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
      <view class="info">
        <text class="nickname">{{userInfo.nickname || '用户'}}</text>
        <view class="grade-tag" wx:if="{{userInfo.grade}}">
          {{userInfo.grade}}年级 | {{userInfo.textbookVersion === 'pep' ? '人教版' : userInfo.textbookVersion === 'waiyan' ? '外研版' : '牛津版'}}
        </view>
        <view class="vip-badge" wx:if="{{userInfo.isVip}}">
          <text class="vip-icon">👑</text> VIP会员
        </view>
      </view>
    </view>
    
    <view class="user-info" wx:else>
      <view class="avatar-placeholder"></view>
      <view class="info">
        <text class="nickname">未登录</text>
        <view class="login-btn" bindtap="onLogin">点击登录</view>
      </view>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card" wx:if="{{isLogin}}">
    <view class="stat-item">
      <text class="number">{{stats.totalWords}}</text>
      <text class="label">已学单词</text>
    </view>
    <view class="stat-item">
      <text class="number">{{stats.masteredWords}}</text>
      <text class="label">已掌握</text>
    </view>
    <view class="stat-item">
      <text class="number">{{stats.continuousDays}}</text>
      <text class="label">连续打卡</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <!-- 学习报告 -->
    <view class="menu-item" bindtap="onViewReport" wx:if="{{isLogin}}">
      <view class="menu-left">
        <text class="icon">📊</text>
        <text class="title">学习报告</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- VIP会员 -->
    <view class="menu-item vip-item" bindtap="onBuyVip" wx:if="{{isLogin}}">
      <view class="menu-left">
        <text class="icon">👑</text>
        <text class="title">VIP会员</text>
      </view>
      <view class="menu-right">
        <text class="badge" wx:if="{{!userInfo.isVip}}">未开通</text>
        <text class="badge active" wx:else>已开通</text>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 设置 -->
    <view class="menu-item" bindtap="onSettings" wx:if="{{isLogin}}">
      <view class="menu-left">
        <text class="icon">⚙️</text>
        <text class="title">设置</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 联系客服 -->
    <view class="menu-item" bindtap="onContact">
      <view class="menu-left">
        <text class="icon">💬</text>
        <text class="title">联系客服</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 关于 -->
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-left">
        <text class="icon">ℹ️</text>
        <text class="title">关于我们</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 退出登录 -->
    <view class="menu-item logout-item" bindtap="onLogout" wx:if="{{isLogin}}">
      <view class="menu-left">
        <text class="icon">🚪</text>
        <text class="title">退出登录</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>
</view>

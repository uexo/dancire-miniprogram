/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  padding: 60rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 30rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  margin-right: 30rpx;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.grade-tag {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.vip-badge {
  font-size: 24rpx;
  color: #FFD700;
  background: rgba(255,215,0,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  margin-top: 10rpx;
}

.vip-icon {
  margin-right: 6rpx;
}

.login-btn {
  font-size: 28rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  display: inline-block;
  margin-top: 10rpx;
}

/* 学习统计 */
.stats-card {
  display: flex;
  justify-content: space-around;
  background: #fff;
  margin: -40rpx 30rpx 30rpx;
  padding: 40rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.number {
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
}

.label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 功能菜单 */
.menu-list {
  margin: 0 30rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.title {
  font-size: 30rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.badge {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.badge.active {
  color: #FFD700;
  background: rgba(255,215,0,0.1);
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

.vip-item .title {
  color: #FF6B35;
  font-weight: 500;
}

.logout-item .title {
  color: #f44336;
}

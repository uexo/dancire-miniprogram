# 服务器端口
PORT=3000

# JWT 配置
JWT_SECRET=your-jwt-secret-key-minimum-32-characters
JWT_EXPIRES_IN=7d

# 微信小程序配置
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret

# 微信支付配置
WX_MCH_ID=your-mch-id
WX_API_KEY=your-api-key
WX_NOTIFY_URL=https://api.wordheat.com/api/v1/payment/notify
WX_CERT_PATH=/path/to/cert.pem
WX_KEY_PATH=/path/to/key.pem

# 数据库配置 (MySQL 模式)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=wordheat
DB_POOL_LIMIT=20

# SQLite 模式（开发环境）
# USE_SQLITE=true
# SQLITE_PATH=./wordheat.sqlite

# TTS 配置
TTS_PROVIDER=baidu
TTS_APP_ID=your-tts-app-id
TTS_API_KEY=your-tts-api-key
TTS_SECRET_KEY=your-tts-secret-key

# 环境
NODE_ENV=development

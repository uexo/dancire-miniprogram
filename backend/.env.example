# 单词热 - 环境配置
NODE_ENV=development

# 服务器配置
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wordheat

# JWT密钥
JWT_SECRET=your-jwt-secret-key-change-in-production

# 微信小程序配置
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret

# 微信支付配置
WX_MCH_ID=your-mch-id
WX_API_KEY=your-api-key
WX_NOTIFY_URL=https://api.wordheat.com/api/v1/payment/notify

# 可选：TTS服务配置（百度/腾讯/阿里云）
TTS_PROVIDER=baidu
TTS_APP_ID=your-tts-app-id
TTS_API_KEY=your-tts-api-key
TTS_SECRET_KEY=your-tts-secret-key

{
  "apps": [{
    "name": "wordheat",
    "script": "./src/app.js",
    "cwd": "/var/www/wordheat/backend",
    "instances": 1,
    "exec_mode": "fork",
    "env": {
      "NODE_ENV": "production"
    },
    "log_file": "./logs/combined.log",
    "out_file": "./logs/out.log",
    "error_file": "./logs/error.log",
    "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
    "merge_logs": true,
    "max_memory_restart": "500M",
    "restart_delay": 3000,
    "max_restarts": 10,
    "min_uptime": "10s",
    "kill_timeout": 5000,
    "listen_timeout": 10000,
    "autorestart": true,
    "watch": false
  }]
}
